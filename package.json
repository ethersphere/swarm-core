{
  "name": "swarm-core-lib",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bytes": {
      "types": "./dist/bytes/index.d.ts",
      "import": "./dist/bytes/index.js",
      "require": "./dist/bytes/index.cjs"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs"
    },
    "./chunk": {
      "types": "./dist/chunk/index.d.ts",
      "import": "./dist/chunk/index.js",
      "require": "./dist/chunk/index.cjs"
    },
    "./mantaray": {
      "types": "./dist/mantaray/index.d.ts",
      "import": "./dist/mantaray/index.js",
      "require": "./dist/mantaray/index.cjs"
    },
    "./erasure-coding": {
      "types": "./dist/erasure-coding/index.d.ts",
      "import": "./dist/erasure-coding/index.js",
      "require": "./dist/erasure-coding/index.cjs"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "import": "./dist/encryption/index.js",
      "require": "./dist/encryption/index.cjs"
    },
    "./stamper": {
      "types": "./dist/stamper/index.d.ts",
      "import": "./dist/stamper/index.js",
      "require": "./dist/stamper/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run --outputJson .tmp/bench-report.json && node scripts/check-bench-regression.mjs .tmp/bench-report.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
